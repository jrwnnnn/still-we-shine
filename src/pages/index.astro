---
import { createClient } from "@libsql/client";
import { BlobServiceClient } from "@azure/storage-blob";
import { setPosition } from "../utils/algorithm/multi-parallax";
import { hashSeed } from "@utils/random";
import { getRandomStar } from "@utils/star";
import renderStar from "@utils/renderStar";
import Layout from "@layouts/Layout.astro";
import Star from "@components/Star.astro";
import Sky from "@components/Sky.astro";
import Form from "@components/Form.astro";
import starCatalog from "../data/star-catalog.json";

const turso = createClient({
	url: import.meta.env.TURSO_DATABASE_URL,
	authToken: import.meta.env.TURSO_AUTH_TOKEN,
});

let error = "";

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();

	const token = formData.get("recaptcha_token");
	const recaptchaVerify = await fetch(
		`https://www.google.com/recaptcha/api/siteverify?secret=${import.meta.env.RECAPTCHA_SECRET_KEY}&response=${token}`,
		{
			method: "POST",
		},
	);
	const recaptchaData = await recaptchaVerify.json();

	const name = (formData.get("name") as string)?.trim();
	const birthYear = (formData.get("birth_year") as string)?.trim();
	const deathYear = (formData.get("death_year") as string)?.trim();
	const message = (formData.get("message") as string)?.trim();
	const image = formData.get("image") as File;
	const star = getRandomStar();

	if (
		!recaptchaData.success ||
		recaptchaData.score < 0.5 ||
		recaptchaData.action !== "submit"
	) {
		error = "Security check failed. Please try again.";
	} else if (image && image.size > 2 * 1024 * 1024) {
		error = "Image must be under 2MB.";
	} else if (parseInt(birthYear) > parseInt(deathYear)) {
		error = "Birth year must be before death year.";
	} else {
		let imageUrl = null;

		if (image && image.size > 0) {
			try {
				const blobService = BlobServiceClient.fromConnectionString(
					import.meta.env.AZURE_CONNECTION_STRING,
				);
				const containerClient = blobService.getContainerClient("images");
				const fileName = `${Date.now()}-${image.name.replace(/\s+/g, "-")}`;
				const blobClient = containerClient.getBlockBlobClient(fileName);

				const arrayBuffer = await image.arrayBuffer();
				await blobClient.uploadData(arrayBuffer, {
					blobHTTPHeaders: { blobContentType: image.type },
				});
				imageUrl = blobClient.url;
			} catch (e) {
				error = "Failed to upload image.";
			}
		}

		if (!error) {
			const result = await turso.execute({
				sql: "INSERT INTO stars (star_hr, name, birth_year, death_year, message, image_url) VALUES (?, ?, ?, ?, ?, ?)",
				args: [star.HR, name, birthYear, deathYear, message, imageUrl],
			});

			return Astro.redirect("/?focus=" + result.lastInsertRowid);
		}
	}
}

const entries = await turso.execute("SELECT * FROM stars");
const starByHR = Object.fromEntries(starCatalog.map((s) => [s.HR, s]));

const stars = entries.rows
	.map((row) => {
		const starData = starByHR[row.star_hr as string];
		if (!starData) return null;

		const visual = renderStar(starData, row);
		if (!visual) return null;

		const seed = hashSeed(
			`${row.star_hr}-${row.name}-${row.birth_year}-${row.death_year}-${row.timestamp}`,
		);
		const pos = setPosition(seed);

		return {
			id: row.id,
			...visual,
			x: pos.x,
			y: pos.y,
			starName: starData?.Name || starData?.ID,
			name: row.name,
			birthYear: row.birth_year,
			deathYear: row.death_year,
		};
	})
	.filter((s): s is NonNullable<typeof s> => s !== null);
---

<Layout>
	<div id="viewport" class="bg-sky-dark fixed inset-0 overflow-hidden">
		<!-- TODO: Canvas (the final boss) -->
		<div
			id="canvas"
			class="flex h-[375vmax] w-[375vmax] items-center justify-center md:h-[187.5vmax]"
		>
			<Sky star_intensity="1000" meteor_count="3" />
			{
				stars.map((s) => (
					<a
						href={`/star/${s.id}`}
						class="absolute flex flex-col items-center"
						style={`left:${s.x}%;top:${s.y}%; will-change: opacity, transform;`}
					>
						<div class="peer" id={s.id as string}>
							<Star
								color={s.color}
								size={s.size}
								glow={s.glow}
								beamLen={s.beamLen}
								beamW={s.beamW}
								pulseDelay={s.pulseDelay}
								animateIn={true}
								animateDelay={true}
							/>
						</div>

						<div class="focused:opacity-100 pointer-events-none z-25 mt-5 text-center text-[0.8rem] leading-snug whitespace-nowrap opacity-0 transition-opacity peer-hover:opacity-100">
							<p class="text-white/50">{s.starName}</p>
							<p class="text-sm! font-medium" style={`color:${s.color};`}>
								{s.name}
							</p>
							<p class="text-white/40">
								{s.birthYear} – {s.deathYear}
							</p>
						</div>
					</a>
				))
			}
		</div>
	</div>
	<div
		class="pointer-events-none fixed inset-0 z-50 flex h-full flex-col justify-between p-5"
	>
		<div space-y-2>
			<a
				href="about"
				class="pointer-events-auto cursor-pointer text-xl font-bold tracking-[5px] uppercase"
			>
				Still, They Shine
			</a>
			<p class="text-xs opacity-50">{stars.length} companions watching from above</p>
		</div>
		<div
			class="flex flex-col items-end gap-2 self-end md:flex-row md:items-center"
		>
			<!-- <button
				onclick="document.getElementById('ambient').muted = !document.getElementById('ambient').muted"
				class="pointer-events-auto cursor-pointer rounded-full bg-white/5 px-4 py-2 text-white hover:bg-white/10"
			>
				<img
					class="h-5 object-contain invert"
					src="/icons/sound.svg"
					loading="lazy"
					alt="GitHub Icon"
				/>
			</button> -->
			<button
				id="openBtn"
				class="pointer-events-auto cursor-pointer rounded-full bg-white/5 px-4 py-2 text-white hover:bg-white/10"
			>
				<span class="mr-1.25">✦</span>Place a Star
			</button>
		</div>
	</div>
	<div
		id="formModal"
		class="fixed inset-0 z-100 hidden h-full w-full items-center justify-center p-5"
	>
		<div
			id="formBackdrop"
			class="pointer-events-auto fixed inset-0 backdrop-blur-sm"
		>
		</div>

		<Form error={error} />
	</div>
</Layout>

<script>
	import Panzoom from "@panzoom/panzoom";
	import { focusStar } from "@utils/focusStar";

	const canvas = document.getElementById("canvas")!;
	const viewport = document.getElementById("viewport")!;

	const panzoom = Panzoom(canvas, {
		maxScale: 10,
		minScale: 0.2,
		contain: "outside",
		canvas: true,
		cursor: "arrow",
		startScale: 0.2,
		startX: -(canvas.offsetWidth - window.innerWidth) / 2,
		startY: -(canvas.offsetHeight - window.innerHeight) / 2,
	});

	viewport.addEventListener("wheel", panzoom.zoomWithWheel, {
		passive: false,
	});

	(window as any).focusStar = (id: string | number) => focusStar(panzoom, id);
	const urlParams = new URLSearchParams(window.location.search);
	if (urlParams.get("focus")) {
		setTimeout(() => focusStar(panzoom, urlParams.get("focus") as string), 100);
	}
</script>
<script>
	const formModal = document.getElementById("formModal")!;
	const formBackdrop = document.getElementById("formBackdrop")!;
	const openBtn = document.getElementById("openBtn")!;
	const closeBtn = document.getElementById("exitBtn")!;

	function toggleForm() {
		if (formModal.classList.contains("hidden")) {
			formModal.classList.remove("hidden");
			formModal.classList.add("flex");
			openBtn.setAttribute("disabled", "");
		} else {
			formModal.classList.add("hidden");
			formModal.classList.remove("flex");
			openBtn.removeAttribute("disabled");
		}
	}

	[openBtn, closeBtn, formBackdrop].forEach((el) => {
		el.addEventListener("click", toggleForm);
	});
</script>
