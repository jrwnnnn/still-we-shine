---
interface Props {
	color: string;
	size: number;
	glow: number;
	beamLen: number;
	beamW: number;
	pulseDelay: string;
}

const { color, size, glow, beamLen, beamW, pulseDelay } = Astro.props;
---

<div
	class="star z-2 cursor-pointer"
	style={`--color:${color};--size:${size}px;--glow:${glow};--beam-len:${beamLen}px;--beam-w:${beamW}px;--pulse-delay:${pulseDelay}s;`}
>
</div>

<style is:global>
	.star {
		width: var(--size);
		height: var(--size);
		border-radius: 50%;
		background: radial-gradient(
			circle,
			#fff 0%,
			var(--color) 60%,
			transparent 100%
		);
		opacity: 0;
		box-shadow:
			0 0 calc(var(--size) * 1) calc(var(--size) * 0.3) var(--color),
			0 0 calc(var(--size) * 2.5) calc(var(--size) * 0.6)
				color-mix(in srgb, var(--color) 40%, transparent);
		transition: filter 0.2s;

		-webkit-backface-visibility: hidden;
		backface-visibility: hidden;
		transform-style: preserve-3d;
		image-rendering: auto;

		animation:
			star-appear 0.5s ease-out forwards,
			star-pulse 3s ease-in-out infinite;
		animation-delay:
			var(--pulse-delay, 0s), calc(var(--pulse-delay, 0s) + 0.8s);
	}

	.star:hover {
		filter: brightness(1.4);
		animation-play-state: paused;
	}

	.star:hover::before {
		width: calc(var(--beam-len) * 1.5);
	}

	.star:hover::after {
		height: calc(var(--beam-len) * 1.75);
	}

	.star::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: var(--beam-len);
		height: var(--beam-w);
		transition:
			width 0.3s ease,
			height 0.3s ease;
		background: linear-gradient(
			90deg,
			transparent 0%,
			color-mix(in srgb, var(--color) 15%, transparent) 20%,
			color-mix(in srgb, var(--color) 50%, transparent) 40%,
			#fff 50%,
			color-mix(in srgb, var(--color) 50%, transparent) 60%,
			color-mix(in srgb, var(--color) 15%, transparent) 80%,
			transparent 100%
		);
		pointer-events: none;
	}

	.star::after {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		height: var(--beam-len);
		width: var(--beam-w);
		transition:
			width 0.3s ease,
			height 0.3s ease;
		background: linear-gradient(
			180deg,
			transparent 0%,
			color-mix(in srgb, var(--color) 15%, transparent) 20%,
			color-mix(in srgb, var(--color) 50%, transparent) 40%,
			#fff 50%,
			color-mix(in srgb, var(--color) 50%, transparent) 60%,
			color-mix(in srgb, var(--color) 15%, transparent) 80%,
			transparent 100%
		);
		pointer-events: none;
	}

	@keyframes star-appear {
		0% {
			opacity: 0;
			transform: scale(0);
		}
		60% {
			opacity: var(--glow);
			transform: scale(1.3);
		}
		100% {
			opacity: var(--glow);
			transform: scale(1);
		}
	}

	@keyframes star-pulse {
		0%,
		100% {
			opacity: var(--glow);
		}
		50% {
			opacity: calc(var(--glow) * 0.6);
		}
	}
</style>
