---
const { error, isBlocked } = Astro.props;
---

<div
	class="bg-sky-dark/70 flex w-full flex-col space-y-6 rounded-2xl p-8 shadow-xl shadow-black/30 backdrop-blur-md md:max-w-md"
>
	<div>
		<div class="mb-4 flex justify-between">
			<p
				class="text-xl text-indigo-200/50 [text-shadow:0_0_12px_rgba(199,210,254,0.4)]"
			>
				✦
			</p>
			<button
				id="exitBtn"
				class="cursor-pointer text-2xl text-white/40 transition hover:text-white"
			>
				&times;
			</button>
		</div>
		<h1 class="mb-2 text-2xl font-medium tracking-tight text-white">
			Place a Star
		</h1>
		<p class="text-sm leading-relaxed text-white/45">
			Dedicate a star in the sky to a companion you want to remember.
		</p>
	</div>

	{
		error && (
			<div class="flex gap-3 rounded-xl border border-red-400/15 bg-red-500/8 px-4 py-3 text-sm text-red-300/90">
				<span class="mt-px shrink-0 text-red-400/70">⚠</span>
				<span>{error}</span>
			</div>
		)
	}

	<form id="form" method="POST" class="space-y-5" enctype="multipart/form-data">
		<label for="name" class="form-label">Name</label>
		<input
			type="text"
			name="name"
			required
			autocomplete="off"
			class="form-input"
			disabled={isBlocked}
		/>

		<div class="grid grid-cols-2 gap-3">
			<div>
				<label for="birth_year" class="form-label">Born</label>
				<input
					type="number"
					name="birth_year"
					required
					autocomplete="off"
					min="1900"
					max={new Date().getFullYear()}
					class="form-input"
					disabled={isBlocked}
				/>
			</div>
			<div>
				<label for="death_year" class="form-label">Passed</label>
				<input
					type="number"
					name="death_year"
					required
					autocomplete="off"
					min="1900"
					max={new Date().getFullYear()}
					class="form-input"
					disabled={isBlocked}
				/>
			</div>
		</div>

		<label for="message" class="form-label">Message</label>
		<textarea
			name="message"
			autocomplete="off"
			class="form-input"
			maxlength="500"
			disabled={isBlocked}></textarea>

		<input
			type="file"
			name="image"
			accept="image/png,image/jpeg,image/jpg,image/webp"
			class="w-full cursor-pointer text-sm text-white/40 file:mr-4 file:cursor-pointer file:rounded-xl file:border file:border-white/10 file:bg-white/6 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white/75 file:transition-all hover:file:bg-white/10 hover:file:text-white"
			disabled={isBlocked}
		/>

		<div class="pt-1">
			<button
				type="submit"
				class="w-full cursor-pointer rounded-xl border border-white/10 bg-white/6 px-5 py-3 text-sm font-medium text-white/75 transition-all duration-200 hover:border-white/20 hover:bg-white/10 hover:text-white hover:shadow-[0_0_24px_rgba(255,255,255,0.05)]"
				disabled={isBlocked}
			>
				Submit
			</button>
		</div>
	</form>
	<a
		href="legal#privacy"
		class="self-center text-xs text-white/40 hover:underline"
	>
		Privacy Policy
	</a>
</div>

<style is:global>
	@reference "../styles/global.css";

	.form-label {
		@apply mb-1.5 block text-xs font-medium tracking-widest text-white/40 uppercase;
	}
	.form-input {
		@apply w-full rounded-xl border border-white/8 bg-white/4 px-4 py-2.5 text-sm text-white transition-shadow duration-200 outline-none placeholder:text-white/20 focus:border-indigo-200/25 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none;
	}
</style>
